# Copy this file to ".env" and fill in your own values. Never share your real .env file.

# Your bot's token from https://discord.com/developers/applications
# This must be a DIFFERENT bot application than your other bot — create a new
# application in the Developer Portal for this one.
DISCORD_TOKEN=your_bot_token_here

# The command prefix people type before the command
PREFIX=!

# The voice channel ID(s) that count as "recording sessions".
# Separate multiple channel IDs with commas, e.g. 1213894066518098003,1216157626749161492
# Right-click a voice channel (with Developer Mode on) > Copy Channel ID.
TRACKED_VC_IDS=

# The role ID(s) for your Recording Crew roles — you can list all 3 here.
# Separate multiple role IDs with commas, e.g. 111111111,222222222,333333333
TRACKED_ROLE_ID=

# Only members with one of these role IDs can run !inactivity / !lastseen.
# Separate multiple role IDs with commas. If left blank, anyone with "Manage Roles" can use it.
ALLOWED_ROLE_ID=
